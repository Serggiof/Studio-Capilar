{
  "name": "studio-capilar",
  "version": "1.0.0",
  "description": "Sistema de gestión para Studio Capilar",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.studiocapilar.app",
    "productName": "Studio Capilar",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  },
  "keywords": [],
  "author": "Studio Capilar",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "file-saver": "^2.0.5"
  }
}
